# Vercel 환경변수에 같은 이름으로 입력하세요. 실제 키는 이 파일에 넣지 않습니다.

# AI provider keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model defaults. 최신 모델이 바뀌면 Vercel 환경변수에서 이 값만 바꾸면 됩니다.
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-2
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-pro-image

# Aladin OpenAPI TTB key
ALADIN_TTB_KEY=

# 선택: Google Apps Script Web App URL. 결과를 구글 시트에 저장하고 싶을 때만 사용합니다.
GOOGLE_SHEET_WEBHOOK_URL=

# 선택: 저장 API를 보호할 간단한 토큰. 수업 실습에서는 비워두어도 됩니다.
APP_SECRET=
